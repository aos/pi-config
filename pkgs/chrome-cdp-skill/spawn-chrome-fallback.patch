+// Quick TCP probe to check if a port is actually listening
+function isPortOpen(host, port, timeoutMs = 1000) {
+  return new Promise((resolve) => {
+    const sock = net.connect({ host, port }, () => {
+      sock.destroy();
+      resolve(true);
+    });
+    sock.on('error', () => resolve(false));
+    sock.setTimeout(timeoutMs, () => { sock.destroy(); resolve(false); });
+  });
+}
+
+function findChromeBinary() {
+  const plat = platform();
+  // macOS: check well-known app paths
+  if (plat === 'darwin') {
+    const macApps = [
+      '/Applications/Google Chrome.app/Contents/MacOS/Google Chrome',
+      '/Applications/Chromium.app/Contents/MacOS/Chromium',
+      '/Applications/Brave Browser.app/Contents/MacOS/Brave Browser',
+      '/Applications/Microsoft Edge.app/Contents/MacOS/Microsoft Edge',
+    ];
+    for (const p of macApps) { if (existsSync(p)) return p; }
+  }
+  // Linux: resolve bare names via which
+  if (plat === 'linux') {
+    const names = [
+      'google-chrome-stable', 'google-chrome', 'chromium-browser', 'chromium',
+      'brave-browser', 'microsoft-edge',
+    ];
+    for (const name of names) {
+      try {
+        const p = execSync(`which ${name}`, { encoding: 'utf8', stdio: ['pipe', 'pipe', 'pipe'] }).trim();
+        if (p) return p;
+      } catch {}
+    }
+  }
+  // Windows
+  if (plat === 'win32') {
+    const pf = process.env.PROGRAMFILES || 'C:\\Program Files';
+    const pf86 = process.env['PROGRAMFILES(X86)'] || 'C:\\Program Files (x86)';
+    const local = process.env.LOCALAPPDATA || resolve(homedir(), 'AppData', 'Local');
+    const winApps = [
+      resolve(pf, 'Google/Chrome/Application/chrome.exe'),
+      resolve(pf86, 'Google/Chrome/Application/chrome.exe'),
+      resolve(local, 'Google/Chrome/Application/chrome.exe'),
+    ];
+    for (const p of winApps) { if (existsSync(p)) return p; }
+  }
+  return null;
+}
+
+async function spawnChromeAndGetWsUrl() {
+  const bin = findChromeBinary();
+  if (!bin) throw new Error('No Chrome/Chromium binary found and no existing DevToolsActivePort. Install Chrome or enable remote debugging on a running browser.');
+
+  try { mkdirSync(SPAWNED_CHROME_DIR, { recursive: true, mode: 0o700 }); } catch {}
+
+  // Remove stale DevToolsActivePort so we can detect the fresh one
+  const portFilePath = resolve(SPAWNED_CHROME_DIR, 'DevToolsActivePort');
+  try { unlinkSync(portFilePath); } catch {}
+
+  process.stderr.write(`Spawning Chrome: ${bin}\n`);
+  const child = spawn(bin, [
+    '--remote-debugging-port=0',
+    `--user-data-dir=${SPAWNED_CHROME_DIR}`,
+    '--no-first-run',
+    '--no-default-browser-check',
+    '--disable-default-apps',
+  ], {
+    detached: true,
+    stdio: 'ignore',
+  });
+  child.unref();
+
+  // Record PID so we could clean up later if needed
+  try { writeFileSync(SPAWNED_CHROME_PID, String(child.pid), { mode: 0o600 }); } catch {}
+
+  // Wait for DevToolsActivePort to appear
+  const deadline = Date.now() + CHROME_SPAWN_TIMEOUT;
+  while (Date.now() < deadline) {
+    await sleep(200);
+    if (existsSync(portFilePath)) {
+      const info = readPortFile(portFilePath);
+      if (info) {
+        process.stderr.write(`Chrome spawned, CDP available.\n`);
+        return info.wsUrl;
+      }
+    }
+  }
+  throw new Error(`Timed out waiting for Chrome to start and write DevToolsActivePort at ${portFilePath}`);
+}
+
+async function getWsUrl() {
+  const info = findExistingPortFile();
+  if (info) {
+    // Verify the port is actually listening (not a stale file from a dead process)
+    if (await isPortOpen(info.host, info.port)) return info.wsUrl;
+    process.stderr.write(`Found DevToolsActivePort but port ${info.port} is not listening (stale).\n`);
+  }
+  return spawnChromeAndGetWsUrl();
 }
 
